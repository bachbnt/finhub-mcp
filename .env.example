#
# finance-mcp environment configuration
# Copy this file to .env, then fill in real values.
#   cp .env.example .env

# Telegram alerts (required only when using alert_daemon.py)
#
# How to get a token:
#   1. Message @BotFather on Telegram and run /newbot.
#   2. Name the bot and copy the returned token.
#
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Alert daemon
#
# Price check interval in seconds. Default is 60s.
# Lower values make alerts faster but increase API rate-limit risk.
#
CHECK_INTERVAL=60
